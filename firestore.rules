rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net (Denegar todo por defecto)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in ['arrucha@theglobal.school', 'roberto@pro-latam.org'];
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidPartner(data) {
      return data.keys().hasAll(['name', 'email', 'organization', 'status', 'referralCode', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.organization is string && data.organization.size() <= 200 &&
             data.referralCode is string && data.referralCode.size() <= 20 &&
             data.status in ['active', 'suspended', 'pending', 'rejected'];
    }

    function isValidCoupon(data) {
      return data.keys().hasAll(['code', 'discount', 'partnerId', 'status', 'createdAt']) &&
             data.code is string && data.code.size() <= 50 &&
             data.discount is number && data.discount >= 0 &&
             (isAdmin() ? data.discount <= 100 : data.discount <= 30) &&
             data.partnerId is string &&
             data.status in ['active', 'inactive'];
    }

    // --- Partners ---
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(partnerId) && isValidPartner(incoming());
      // Non-admin partners can update their own profile but CANNOT change status
      allow update: if (isOwner(partnerId) && isValidPartner(incoming()) && incoming().status == existing().status) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Coupons ---
    match /coupons/{couponId} {
      allow read: if true;
      // Only the partner who owns the coupon can create it (partnerId must match auth uid)
      allow create: if isSignedIn() && isValidCoupon(incoming()) && incoming().partnerId == request.auth.uid;
      // Only owner or admin can update; cannot reassign coupon to another partner
      allow update: if (isSignedIn() && existing().partnerId == request.auth.uid && isValidCoupon(incoming()) && incoming().partnerId == existing().partnerId) || isAdmin();
      // Only owner or admin can delete
      allow delete: if (isSignedIn() && existing().partnerId == request.auth.uid) || isAdmin();
    }

    // --- Nominees ---
    match /nominees/{nomineeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Votes ---
    match /votes/{voteId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // --- Nomination Requests ---
    match /nominationRequests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // --- Registrations ---
    match /registrations/{regId} {
      // list: signed-in users can query; client MUST filter by partnerId == auth.uid
      // (Firestore rules cannot enforce field-level filters on list queries)
      allow list: if isSignedIn();
      allow get: if true;
      allow create: if true;
      allow update: if isAdmin();
    }

    // --- Voted IPs ---
    match /voted_ips/{ip} {
      allow read, write: if true;
    }

    // --- Free Registrations ---
    match /free_registrations/{regId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
