rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net (Denegar todo por defecto)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email in ['arrucha@theglobal.school', 'roberto@pro-latam.org']; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidPartner(data) {
      return data.keys().hasAll(['name', 'email', 'organization', 'status', 'referralCode', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.organization is string && data.organization.size() <= 200 &&
             data.referralCode is string && data.referralCode.size() <= 20 &&
             data.status in ['active', 'suspended', 'pending'];
    }

    function isValidCoupon(data) {
      return data.keys().hasAll(['code', 'discount', 'partnerId', 'status', 'createdAt']) &&
             data.code is string && data.code.size() <= 50 &&
             data.discount is number && data.discount >= 0 && 
             (isAdmin() ? data.discount <= 100 : data.discount <= 30) && // Límite del 30% para Partners
             data.partnerId is string &&
             data.status in ['active', 'inactive'];
    }

    // --- Partners ---
    match /partners/{partnerId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(partnerId) && isValidPartner(incoming());
      allow update: if (isOwner(partnerId) && isValidPartner(incoming())) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Coupons ---
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Nominees ---
    match /nominees/{nomineeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Votes ---
    match /votes/{voteId} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // --- Nomination Requests ---
    match /nominationRequests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // --- Registrations ---
    match /registrations/{regId} {
      allow list: if isSignedIn() && (resource.data.partnerId == request.auth.uid || isAdmin());
      allow get: if true; 
      allow create: if true; 
      allow update: if isAdmin();
    }
    
    // --- Voted IPs ---
    match /voted_ips/{ip} {
      allow read, write: if true;
    }

    // --- Free Registrations ---
    match /free_registrations/{regId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
